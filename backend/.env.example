# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/log_monitor
MONGODB_URI_DOCKER=mongodb://mongodb:27017/log_monitor

# JWT Configuration
JWT_SECRET=change-me-to-a-strong-random-secret
JWT_EXPIRE=7d

# Server Configuration
PORT=5000
NODE_ENV=development

# Kafka Configuration
KAFKA_BROKER=localhost:9092
KAFKA_BROKER_DOCKER=kafka:9092
KAFKA_TOPIC_RAW_LOGS=raw-logs
KAFKA_TOPIC_PROCESSED_LOGS=processed-logs
KAFKA_TOPIC_ANOMALIES=anomalies
KAFKA_GROUP_ID=log-monitor-backend

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# AI Service URL
AI_SERVICE_URL=http://localhost:8000

# Notification Settings (set your own values)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Log Levels
LOG_LEVEL=info
